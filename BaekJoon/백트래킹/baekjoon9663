# N-QUEEN 문제

import sys
input = sys.stdin.readline

N = int(input())
rs = 0
row = [0] * N

def check(x):
    for i in range(x):
        if row[x] == row[i] or abs(row[x] - row[i]) == abs(x - i): # 같은 열과 대각선 검사
            return False
    return True

def n_queens(x):
    global rs
    if x == N:
        rs += 1
        return
    else:
        for i in range(N):
            # [x, i]에 퀸을 놓겠다.
            row[x] = i
            if check(x):
                n_queens(x+1)
n_queens(0)
print(rs)