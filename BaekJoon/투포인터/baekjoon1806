import sys
input = sys.stdin.readline

n,s = map(int, input().split())
arr = list(map(int, input().split()))

left, right = 0,0
sum = 0
minlen = 1e7

while True:
    if sum >= s:
        minlen = min(minlen, right - left)
        sum -= arr[left]
        left += 1
    elif right == n:
        break
    else:
        sum += arr[right]
        right += 1

if minlen == 1e7:
    print(0)
else:
    print(minlen)
