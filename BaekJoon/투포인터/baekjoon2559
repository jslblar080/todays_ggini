# 투 포인터
# 투 포인터 Tip!! 쉬운 방법부터 생각 했을 때 시간복잡도 O(N^2)이 되어 시간 초과가 되고 연속적이라는 특성을 활용할 수 있다면 투 포인터 생각
# 투 포인터 문제 종류: 두개 다 왼쪽에서/ 각각 왼쪽, 오른쪽/ 다른 배열
# 일반적으로 O(N), 정렬 후 투 포인터 O(NlgN)

import sys
input = sys.stdin.readline

N, K = map(int, input().split())
numlist = list(map(int, input().split()))

val = 0
for j in range(K):
        val += numlist[j]

maxv = val

for i in range(K, N):
    val += numlist[i]
    val -= numlist[i-K]
    maxv = max(maxv, val)

print(maxv)