# MST(Minimum Spanning Tree) 
# 기본문제 암기!!(시간복잡도 : O(ElgE))
# MST Tip!! 최소 스패닝 트리 코드는 그냥 외우기! 중요한 건 해당 문제가 MST 문제인지 알아내는 능력, 
#           모든 노드가 연결되도록 한다거나 이미 연결된 노드를 최소의 비용으로 줄이기
# 이 풀이는 프림(prim) 알고리즘 풀이법

import sys
import heapq
input = sys.stdin.readline

V, E = map(int, input().split())
edge = [[] for _ in range(V+1)]
chk = [False] * (V+1)
rs = 0
for _ in range(E):
    a,b,c = map(int, input().split())
    edge[a].append([c,b])
    edge[b].append([c,a])

heap = [[0,1]]

while heap:
    w, each_node = heapq.heappop(heap)
    if chk[each_node] == False:
        chk[each_node] = True
        rs += w
        for next_edge in edge[each_node]:
            if chk[next_edge[1]] == False:
                heapq.heappush(heap, next_edge)

print(rs)