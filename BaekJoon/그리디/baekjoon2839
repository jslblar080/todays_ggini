# 그리디 알고리즘

import sys
input = sys.stdin.readline

N = int(input())

if N % 5 == 0:  # 5으로 나눠떨어질 때
    print(N // 5)
else:
    cnt = 0
    while N > 0:
        N -= 3
        cnt += 1
        if N % 5 == 0:  # 3kg과 5kg를 조합해서 담을 수 있을 때
            cnt += N // 5
            print(cnt)
            break
        elif N == 1 or N == 2:  # 설탕 봉지만으로 나눌 수 없을 때
            print(-1)
            break
        elif N == 0:  # 3으로 나눠떨어질 때
            print(cnt)
            break