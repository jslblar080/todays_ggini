# LIS(가장 긴 증가하는 부분 수열) 문제 -> 길이만 구하면 되는 문제이기 때문에 LIS 수열이 모두 정확할 필요는 없다.

import sys
input = sys.stdin.readline

n = int(input())
arr = list(map(int, input().split()))
LIS = [arr[0]]

def binarySearch(e): # e값이 들어갈 인덱스 위치 찾기
    start = 0
    end = len(LIS) - 1
    
    while start <= end:
        mid = (start + end) // 2
        
        if LIS[mid] == e:
            return mid
        elif LIS[mid] < e:
            start = mid + 1
        else:
            end = mid - 1
            
    return start


for i in range(n):
    if arr[i] > LIS[-1]: # LIS[-1] : 맨 뒤 원소(여기서는 LIS 수열에서 가장 큰 값)
        LIS.append(arr[i])
    else:
        idx = binarySearch(arr[i])
        LIS[idx] = arr[i]

print(len(LIS))