# 이진 탐색
# 이진 탐색 Tip!! 어떤 값을 여러 번 탐색해야 하는 경우, 입력의 개수가 10^5 정도의 경우라면 의심

import sys
input = sys.stdin.readline

N = int(input())
nums = list(map(int, input().split()))
M = int(input())
targets = list(map(int, input().split()))

nums.sort()

def binary_search(start ,end, target): # 함수 형태 암기!!
    if start == end:
        if nums[start] == target:
            print(1)
        else:
            print(0)
        return
        
    mid = (start + end) // 2
    if nums[mid] < target:
        binary_search(mid + 1, end, target)
    else:
        binary_search(start, mid, target)


for k in range(M):
    rs = binary_search(0,N - 1,targets[k])