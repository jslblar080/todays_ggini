FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app/modeling
ENV ENV=prod

WORKDIR /app

RUN addgroup --system appgroup \
    && adduser --system --ingroup appgroup appuser

COPY modeling /app/modeling

RUN pip install --no-cache-dir --upgrade pip \
    && if [ -f /app/modeling/requirements.txt ]; then pip install --no-cache-dir -r /app/modeling/requirements.txt; fi \
    && pip install --no-cache-dir fastapi "uvicorn[standard]"

USER appuser

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import json, urllib.request; data=json.load(urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=3)); assert data.get('status') == 'ok'"

CMD ["uvicorn", "api.server:app", "--host", "0.0.0.0", "--port", "8000"]
